<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <angeo_brand_vis>
            <general>
                <enabled>0</enabled>
                <log_enabled>1</log_enabled>
                <cache_ttl_hours>24</cache_ttl_hours>
            </general>
            <chatgpt>
                <enabled>1</enabled>
                <model>gpt-4.1</model>
                <max_tokens>800</max_tokens>
                <temperature>0.3</temperature>
                <timeout>45</timeout>
            </chatgpt>
            <claude>
                <enabled>0</enabled>
                <model>claude-sonnet-4-6</model>
                <max_tokens>800</max_tokens>
                <timeout>60</timeout>
            </claude>
            <perplexity>
                <enabled>0</enabled>
                <model>sonar</model>
                <max_tokens>800</max_tokens>
                <timeout>45</timeout>
            </perplexity>
            <gemini>
                <enabled>0</enabled>
                <model>gemini-2.5-flash-preview-05-20</model>
                <max_tokens>800</max_tokens>
                <timeout>45</timeout>
            </gemini>
            <groq>
                <enabled>0</enabled>
                <model>llama-3.3-70b-versatile</model>
                <max_tokens>800</max_tokens>
                <timeout>30</timeout>
            </groq>
            <queries>
                <queries_per_provider>3</queries_per_provider>
                <delay_between_ms>500</delay_between_ms>
                <enable_recommendation>1</enable_recommendation>
                <enable_category>1</enable_category>
                <enable_brand_direct>1</enable_brand_direct>
                <enable_product_search>0</enable_product_search>
                <enable_comparison>0</enable_comparison>
                <enable_gift_guide>0</enable_gift_guide>
            </queries>
            <scoring>
                <pass_threshold>60</pass_threshold>
                <warn_threshold>30</warn_threshold>
                <weight_mentioned>1.0</weight_mentioned>
                <weight_recommended>1.5</weight_recommended>
                <weight_url_cited>1.5</weight_url_cited>
                <weight_first_result>2.0</weight_first_result>
                <weight_positive_sentiment>0.5</weight_positive_sentiment>
            </scoring>
            <cron>
                <enabled>0</enabled>
                <schedule>0 5 * * 1</schedule>
            </cron>
        </angeo_brand_vis>
    </default>
</config>
